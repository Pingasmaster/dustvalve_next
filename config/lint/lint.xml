<?xml version="1.0" encoding="UTF-8"?>
<lint>
    <!--
        The app ships translations (values-de/es/fr/it/pt-rBR/ja/zh-rCN/ru).
        Every new default string must land with all 8 translations in the same
        change - machine-translate at PR time, native corrections welcome.
    -->
    <issue id="MissingTranslation"            severity="error" />
    <issue id="ExtraTranslation"              severity="error" />
    <!-- Translation integrity: placeholder parity and plural quantity sets -->
    <issue id="StringFormatInvalid"           severity="error" />
    <issue id="StringFormatMatches"           severity="error" />
    <issue id="StringFormatCount"             severity="error" />
    <issue id="MissingQuantity"               severity="error" />
    <issue id="ImpliedQuantity"               severity="error" />
    <issue id="PluralsCandidate"              severity="error" />
    <!-- i18n hygiene -->
    <issue id="SetTextI18n"                   severity="error" />
    <issue id="TypographyEllipsis"            severity="error" />
    <issue id="TypographyQuotes"              severity="error" />
    <issue id="TypographyDashes"              severity="error" />
    <issue id="RelativeOverlap"               severity="error" />
    <issue id="RtlHardcoded"                  severity="error" />
    <issue id="GoogleAppIndexingWarning"      severity="ignore" />
    <issue id="ObsoleteSdkInt"                severity="error" />

    <!--
        NewerVersionAvailable / AndroidGradlePluginVersion report that some
        dependency in gradle/libs.versions.toml has a newer release. The
        project tracks upgrades via routine dependency review (Dependabot +
        manual sweep), not via lint. With warningsAsErrors = true these
        would otherwise fail lintRelease. Demote to informational so they
        stay visible in editor lint markers without blocking CI.
    -->
    <issue id="NewerVersionAvailable"         severity="informational" />
    <issue id="AndroidGradlePluginVersion"    severity="informational" />
    <issue id="GradleDependency"              severity="informational" />

    <issue id="UnusedResources"               severity="error" />
    <issue id="HardcodedText"                 severity="error" />
    <issue id="ContentDescription"            severity="error" />

    <issue id="NewApi"                        severity="error" />
    <issue id="InlinedApi"                    severity="error" />
    <issue id="MissingPermission"             severity="error" />
    <issue id="ForegroundServiceType"         severity="error" />
    <issue id="BatteryLife"                   severity="error" />

    <issue id="StopShip"                      severity="error" />
    <issue id="VisibleForTests"               severity="error" />

    <issue id="ComposableNaming"              severity="error" />
    <issue id="RememberInComposition"         severity="error" />
    <issue id="ProduceStateDoesNotAssignValue" severity="error" />
    <issue id="UnrememberedMutableState"      severity="error" />
    <issue id="ModifierParameter"             severity="error" />
    <!--
        slack-compose-lints' ComposeUnstableCollections flags every composable
        parameter typed as List<T>/Set<T>/Map<T>. The runtime concern (Compose
        treats kotlin.collections.* as unstable so composables can't skip on
        equal-reference recompositions) is addressed by the project's
        compose_stability_config.conf, which the Compose Compiler reads and
        which marks these as @Stable. The lint check doesn't read that config
        file, so the warnings are noise here. Suppressed globally.
    -->
    <issue id="ComposeUnstableCollections"    severity="ignore" />

    <!--
        slack-lints' AvoidUsingNotNullOperator flags every `!!` usage. In test
        code `!!` is the idiomatic "I'm asserting this is non-null in this
        test path; if it isn't, NPE fails the test with a stack trace pointing
        to the offending line" - equivalent to `requireNotNull(x) { "..." }`
        but more concise, especially in JSON / assertion chains. Refactoring
        ~90 test sites to requireNotNull adds noise without changing failure
        semantics. Suppressed only under src/test and src/androidTest.
    -->
    <issue id="AvoidUsingNotNullOperator">
        <ignore path="**/src/test/**" />
        <ignore path="**/src/androidTest/**" />
    </issue>

    <!--
        slack-lints' DenyListedApi forbids runCatching because in suspend
        contexts it silently swallows CancellationException. In test code
        runCatching{ ... }.exceptionOrNull() is the canonical pattern for
        capturing exceptions in non-suspend assertions, and the
        CancellationException concern does not apply. Production-source
        runCatching calls remain flagged; they are replaced with try/catch +
        explicit cancellation rethrow.
    -->
    <issue id="DenyListedApi">
        <ignore path="**/src/test/**" />
        <ignore path="**/src/androidTest/**" />
    </issue>

    <issue id="RawDispatchersUse"             severity="error" />
</lint>
